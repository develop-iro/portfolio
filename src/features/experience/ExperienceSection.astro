---
import { experience } from './data';
import type { Lang, UIKey } from '../../shared/i18n/translations';

interface Props { lang: Lang; t: (key: UIKey) => string }
const { lang, t } = Astro.props;

const sorted = [...experience].sort((a, b) => b.startDate.localeCompare(a.startDate));

function formatDate(dateStr: string): string {
  const [year, month] = dateStr.split('-');
  const date = new Date(Number(year), Number(month) - 1);
  return date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-GB', { month: 'short', year: 'numeric' });
}
---

<section id="experience" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">{t('exp.heading')}</h2>
    <div class="w-12 h-1 bg-blue-600 rounded mb-12" aria-hidden="true"></div>

    <div class="relative max-w-3xl mx-auto">
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700" aria-hidden="true"></div>

      {sorted.map((entry, i) => (
        <div
          class="timeline-entry relative pl-12 pb-14 last:pb-0 opacity-0 translate-y-8"
          style={`transition-delay: ${i * 120}ms`}
        >
          <div class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full bg-blue-600 ring-4 ring-white dark:ring-gray-900 scale-0 timeline-dot transition-transform duration-300" aria-hidden="true"></div>

          <div class="p-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
              <a
                href={entry.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xl font-semibold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors flex items-center gap-1.5 group"
              >
                {entry.company}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
              <span class="text-xs px-2.5 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full font-medium whitespace-nowrap">
                {formatDate(entry.startDate)} – {entry.endDate ? formatDate(entry.endDate) : t('exp.present')}
              </span>
            </div>
            <p class="text-blue-600 dark:text-blue-400 font-medium mb-3">{entry.title[lang]}</p>
            <ul class="space-y-1.5 list-disc list-inside text-gray-600 dark:text-gray-300 text-sm">
              {entry.responsibilities[lang].map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const entries = document.querySelectorAll<HTMLElement>('.timeline-entry');
  const observer = new IntersectionObserver(
    (observations) => {
      observations.forEach((obs) => {
        if (obs.isIntersecting) {
          const el = obs.target as HTMLElement;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          el.style.transition = `opacity 0.5s ease ${el.style.transitionDelay}, transform 0.5s ease ${el.style.transitionDelay}`;
          const dot = el.querySelector<HTMLElement>('.timeline-dot');
          if (dot) setTimeout(() => dot.classList.remove('scale-0'), 200);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15 }
  );
  entries.forEach((el) => observer.observe(el));
</script>
