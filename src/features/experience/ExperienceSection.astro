---
import { experience } from './data';
import type { Lang, UIKey } from '../../shared/i18n/translations';

interface Props {
  lang: Lang;
  t: (key: UIKey) => string;
}
const { lang, t } = Astro.props;

const sorted = [...experience].sort((a, b) => b.startDate.localeCompare(a.startDate));

function formatDate(dateStr: string): string {
  const [year, month] = dateStr.split('-');
  const date = new Date(Number(year), Number(month) - 1);
  return date.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-GB', {
    month: 'short',
    year: 'numeric',
  });
}
---

<section id="experience" class="px-4 py-20">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-3 text-3xl font-bold text-gray-900 dark:text-white">{t('exp.heading')}</h2>
    <div class="mb-12 h-1 w-12 rounded bg-blue-600" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-3xl">
      <!-- Static track -->
      <div
        class="absolute bottom-0 left-4 top-0 w-0.5 bg-gray-200 dark:bg-gray-700"
        aria-hidden="true"
      >
      </div>
      <!-- Animated fill line -->
      <div
        id="timeline-line"
        class="absolute left-4 top-0 w-0.5 origin-top bg-blue-500"
        style="height:0;transition:height 2s cubic-bezier(0.25,0.46,0.45,0.94)"
        aria-hidden="true"
      >
      </div>

      {
        sorted.map((entry, i) => (
          <div
            class="timeline-entry relative pb-14 pl-12 last:pb-0"
            style={`--delay: ${i * 250}ms`}
          >
            <div
              class="timeline-dot absolute left-2.5 top-1.5 h-3 w-3 scale-0 rounded-full bg-blue-600 ring-4 ring-white dark:ring-gray-900"
              aria-hidden="true"
            />

            <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
              <div class="mb-1 flex flex-wrap items-start justify-between gap-2">
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center gap-1.5 text-xl font-semibold text-gray-900 transition-colors hover:text-blue-600 dark:text-white dark:hover:text-blue-400"
                >
                  {entry.company}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 opacity-0 transition-opacity group-hover:opacity-100"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <>
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </>
                  </svg>
                </a>
                <span class="whitespace-nowrap rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                  {formatDate(entry.startDate)} –{' '}
                  {entry.endDate ? formatDate(entry.endDate) : t('exp.present')}
                </span>
              </div>
              <p class="mb-3 font-medium text-blue-600 dark:text-blue-400">{entry.title[lang]}</p>
              <ul class="list-inside list-disc space-y-1.5 text-sm text-gray-600 dark:text-gray-300">
                {entry.responsibilities[lang].map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline-entry {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) var(--delay, 0ms),
      transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) var(--delay, 0ms);
  }
  .timeline-entry.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .timeline-dot {
    transform: scale(0);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .timeline-dot.is-visible {
    transform: scale(1);
  }
</style>

<script>
  // Animate timeline fill line
  const line = document.getElementById('timeline-line');
  const lineTrack = line?.parentElement?.querySelector<HTMLElement>(
    '.absolute.left-4.top-0.bottom-0'
  );
  if (line && lineTrack) {
    const lineObserver = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          line.style.height = lineTrack.offsetHeight + 'px';
          lineObserver.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    lineObserver.observe(lineTrack);
  }

  const entries = document.querySelectorAll<HTMLElement>('.timeline-entry');
  const observer = new IntersectionObserver(
    (observations) => {
      observations.forEach((obs) => {
        if (obs.isIntersecting) {
          const el = obs.target as HTMLElement;
          el.classList.add('is-visible');
          const dot = el.querySelector<HTMLElement>('.timeline-dot');
          if (dot) {
            const delay = parseFloat(getComputedStyle(el).getPropertyValue('--delay')) || 0;
            setTimeout(() => dot.classList.add('is-visible'), delay + 300);
          }
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1 }
  );
  entries.forEach((el) => observer.observe(el));
</script>
