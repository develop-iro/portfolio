---
import type { Lang, UIKey } from '../../shared/i18n/translations';
interface Props { t: (key: UIKey) => string; lang: Lang }
const { t, lang } = Astro.props;
---

<section id="hero" class="relative min-h-screen max-h-[1080px] max-w-[1440px] mx-auto flex items-end overflow-hidden">
  <img
    src="/images/profile.jpeg"
    alt="Ivan Romero — Frontend Engineer"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 w-full h-full object-cover object-top"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/60 to-transparent"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pb-20 pt-40">
    <span class="inline-block mb-4 px-3 py-1 text-xs font-semibold tracking-widest uppercase bg-blue-600/20 text-blue-300 border border-blue-500/30 rounded-full backdrop-blur-sm">
      {t('hero.badge')}
    </span>

    <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight">
      Ivan Romero
    </h1>

    <p class="mt-4 text-lg md:text-xl text-gray-300 max-w-xl leading-relaxed">
      {t('hero.bio')}
    </p>

    <div class="mt-8 flex gap-4 flex-wrap">
      <a
        href="#projects"
        class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg transition-colors focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950"
      >
        {t('hero.cta.projects')}
      </a>
      <a
        href={`/${lang}/resume`}
        class="px-6 py-3 border border-white/30 hover:border-white/60 text-white font-medium rounded-lg backdrop-blur-sm transition-colors focus-visible:ring-2 focus-visible:ring-white/50 flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {t('hero.cta.resume')}
      </a>
    </div>

    <div class="mt-16 flex items-center gap-2 text-gray-400 text-sm animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/>
      </svg>
      {t('hero.scroll')}
    </div>
  </div>
</section>
