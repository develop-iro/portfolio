---
import type { Lang, UIKey } from '../../shared/i18n/translations';
interface Props {
  t: (key: UIKey) => string;
  lang: Lang;
}
const { t, lang } = Astro.props;
---

<section
  id="hero"
  class="relative mx-auto flex max-h-[1080px] min-h-[78vh] max-w-[1440px] items-end overflow-hidden sm:min-h-screen"
>
  <img
    id="hero-img"
    src="/images/profile.jpeg"
    alt="Ivan Romero — Frontend Engineer"
    loading="eager"
    fetchpriority="high"
    class="absolute w-full object-cover object-[center_20%] will-change-transform"
    style="top:-8%;height:116%"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/70 to-gray-950/10"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-12 pt-24 sm:pb-20 sm:pt-40">
    <h1 class="text-5xl font-bold leading-tight text-white md:text-7xl">Ivan Romero</h1>

    <span
      class="mb-0 mt-4 inline-block rounded-full border border-blue-500/30 bg-blue-600/20 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-blue-300 backdrop-blur-sm"
    >
      {t('hero.badge')}
    </span>

    <p class="mt-3 max-w-xl text-lg leading-relaxed text-gray-300 md:text-xl">
      {t('hero.bio')}
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="#projects"
        class="rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-500 focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950"
      >
        {t('hero.cta.projects')}
      </a>
      <a
        href={`/${lang}/resume`}
        class="flex items-center gap-2 rounded-lg border border-white/30 px-6 py-3 font-medium text-white backdrop-blur-sm transition-colors hover:border-white/60 focus-visible:ring-2 focus-visible:ring-white/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        {t('hero.cta.resume')}
      </a>
    </div>

    <div class="mt-16 flex animate-bounce items-center gap-2 text-sm text-gray-400">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline>
      </svg>
      {t('hero.scroll')}
    </div>
  </div>
</section>

<script>
  const img = document.getElementById('hero-img') as HTMLElement | null;
  if (img) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            img.style.transform = `translateY(${window.scrollY * 0.22}px)`;
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>
