---
import type { PublicKpi } from './data';
import type { Lang } from '../../shared/i18n/translations';
import CountUp from '../../shared/ui/CountUp.tsx';

interface Props {
  kpi: PublicKpi;
  lang: Lang;
  size?: 'default' | 'large';
}

const { kpi, lang, size = 'default' } = Astro.props;
const isNumeric = typeof kpi.value === 'number';
const isLarge = size === 'large';
---

<div
  class:list={[
    'group relative bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700',
    'hover:border-blue-400 dark:hover:border-blue-500 hover:shadow-lg hover:-translate-y-0.5',
    'transition-all duration-300',
    isLarge ? 'p-7' : 'p-5',
  ]}
>
  <!-- Icon -->
  <div
    class:list={[
      'rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center mb-4',
      'group-hover:bg-blue-100 dark:group-hover:bg-blue-900/40 transition-colors',
      isLarge ? 'w-12 h-12' : 'w-10 h-10',
    ]}
  >
    <svg
      class:list={['text-blue-600 dark:text-blue-400', isLarge ? 'w-6 h-6' : 'w-5 h-5']}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      {kpi.iconPaths.map((d) => <path d={d} />)}
    </svg>
  </div>

  <!-- Value -->
  <div
    class:list={[
      'font-bold text-gray-900 dark:text-white mb-1 leading-none',
      isLarge ? 'text-4xl' : 'text-3xl',
    ]}
    aria-label={`${kpi.value}${kpi.unit ?? ''} ${kpi.label[lang]}`}
  >
    {isNumeric && kpi.animated
      ? <CountUp to={kpi.value as number} suffix={kpi.unit ?? ''} client:visible />
      : <span>{kpi.value}{kpi.unit ?? ''}</span>
    }
  </div>

  <!-- Label -->
  <p class:list={['font-semibold text-gray-900 dark:text-white mt-2', isLarge ? 'text-base' : 'text-sm']}>
    {kpi.label[lang]}
  </p>

  <!-- Description -->
  {kpi.description && (
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">
      {kpi.description[lang]}
    </p>
  )}
</div>
