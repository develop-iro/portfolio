---
import { publicKpis } from './data';
import KpiCard from './KpiCard.astro';
import type { Lang, UIKey } from '../../shared/i18n/translations';

interface Props {
  lang: Lang;
  t: (key: UIKey) => string;
}

const { lang, t } = Astro.props;

const highlights = publicKpis.filter((k) => k.highlight);
const secondary  = publicKpis.filter((k) => !k.highlight);
---

<section id="metrics" class="py-20 px-4 bg-white dark:bg-gray-900">
  <div class="max-w-6xl mx-auto">

    <!-- Heading -->
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-3">
      {t('metrics.heading')}
    </h2>
    <div class="w-12 h-1 bg-blue-600 rounded mb-4" aria-hidden="true"></div>
    <p class="text-gray-500 dark:text-gray-400 mb-8">
      {t('metrics.subtitle')}
    </p>

    <!-- Availability badge -->
    <div
      class="inline-flex items-center gap-2.5 px-4 py-2 mb-10 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-full text-sm font-medium text-green-700 dark:text-green-400"
      role="status"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" aria-hidden="true"></span>
      {t('metrics.available')}
    </div>

    <!-- Highlight row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-5">
      {highlights.map((kpi) => (
        <KpiCard kpi={kpi} lang={lang} size="large" />
      ))}
    </div>

    <!-- Secondary row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {secondary.map((kpi) => (
        <KpiCard kpi={kpi} lang={lang} />
      ))}
    </div>

  </div>
</section>
