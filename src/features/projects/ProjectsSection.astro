---
import { projects } from './data';
import ProjectFilter from './ProjectFilter';
import type { Lang, UIKey } from '../../shared/i18n/translations';

interface Props {
  lang: Lang;
  t: (key: UIKey) => string;
}
const { lang, t } = Astro.props;

const categories = [...new Set(projects.flatMap((p) => p.categories))];
---

<section id="projects" class="bg-gray-50 px-4 py-20 dark:bg-gray-800/50">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-3 text-3xl font-bold text-gray-900 dark:text-white">{t('projects.heading')}</h2>
    <div class="mb-4 h-1 w-12 rounded bg-blue-600" aria-hidden="true"></div>
    <p class="mb-10 text-gray-500 dark:text-gray-400">{t('projects.subtitle')}</p>
    <ProjectFilter
      projects={projects}
      categories={categories}
      lang={lang}
      liveDemo={t('projects.liveDemo')}
      repository={t('projects.repo')}
      client:load
    />
  </div>
</section>
