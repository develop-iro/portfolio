---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../shared/ui/Nav.astro';
import { projects } from '../../features/projects/data';
import type { Project } from '../../features/projects/data';
import { useTranslations } from '../../shared/i18n/translations';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
// Project detail pages are language-neutral; default to 'en' for nav/layout.
const lang = 'en' as const;
const t = useTranslations(lang);
---

<BaseLayout title={`${project.title} — Ivan Romero`} lang={lang}>
  <Nav lang={lang} t={t} />
  <main id="main-content">
    <div class="mx-auto max-w-4xl px-4 py-20">
      <a
        href="/#projects"
        class="flex items-center gap-1 text-sm text-blue-600 hover:underline dark:text-blue-400"
      >
        ← Back to Projects
      </a>

      <img
        src={project.thumbnail}
        alt={project.title}
        loading="lazy"
        class="mt-6 max-h-96 w-full rounded-xl bg-gray-100 object-cover dark:bg-gray-700"
      />

      <h1 class="mt-8 text-3xl font-bold text-gray-900 dark:text-white">{project.title}</h1>

      <p class="mt-4 leading-relaxed text-gray-600 dark:text-gray-300">
        {project.longDescription ?? project.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-1.5">
        {
          project.techStack.map((tech) => (
            <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
              {tech}
            </span>
          ))
        }
      </div>

      <div class="mt-6 flex gap-4">
        {
          project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1 text-sm text-blue-600 hover:underline dark:text-blue-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <>
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </>
              </svg>
              Live Demo
            </a>
          )
        }
        {
          project.repoUrl && (
            <a
              href={project.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1 text-sm text-blue-600 hover:underline dark:text-blue-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
              </svg>
              Repository
            </a>
          )
        }
      </div>
    </div>
  </main>
</BaseLayout>
