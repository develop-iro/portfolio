---
import type { UIKey } from '../i18n/translations';
import BugSquasher from '../../features/bug-squasher/BugSquasher.tsx';
interface Props { t: (key: UIKey) => string; lang: string }
const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <BugSquasher client:visible />

  <div class="py-6 px-4 border-t border-gray-200 dark:border-gray-700">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400">
    <p>© {year} Ivan Romero. {t('footer.rights')}</p>
    <div class="flex gap-4">
      <a
        href="https://github.com/develop-iro"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-900 dark:hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 rounded"
        aria-label="GitHub profile"
      >GitHub</a>
      <a
        href="https://www.linkedin.com/in/ivan-ccamilo/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-900 dark:hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-blue-500 rounded"
        aria-label="LinkedIn profile"
      >LinkedIn</a>
    </div>
  </div>
  </div>
</footer>
