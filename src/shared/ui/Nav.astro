---
import ThemeToggle from './ThemeToggle.tsx';
import HamburgerMenu from './HamburgerMenu.tsx';
import type { Lang, UIKey } from '../i18n/translations';

interface Props {
  lang: Lang;
  t: (key: UIKey) => string;
}

const { lang, t } = Astro.props;

const navLinks = [
  { label: t('nav.about'),      href: '#about' },
  { label: t('nav.skills'),     href: '#skills' },
  { label: t('nav.projects'),   href: '#projects' },
  { label: t('nav.experience'), href: '#experience' },
  { label: t('nav.contact'),    href: '#contact' },
];

const otherLang = lang === 'en' ? 'es' : 'en';
const otherLangLabel = lang === 'en' ? 'ES' : 'EN';
---

<header>
  <nav
    aria-label="Main navigation"
    class="sticky top-0 z-50 bg-white/80 dark:bg-gray-900/80 backdrop-blur border-b border-gray-200 dark:border-gray-700"
  >
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <!-- Logo / Brand -->
      <a
        href="#hero"
        class="text-lg font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors tracking-tight"
      >
        iro<span class="text-blue-600 dark:text-blue-400">.dev</span>
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-6 list-none m-0 p-0">
        {navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: lang toggle + theme + hamburger -->
      <div class="flex items-center gap-3">
        <!-- Language toggle -->
        <div class="flex items-center gap-1.5 text-xs font-semibold tracking-wide">
          <span class="text-blue-600 dark:text-blue-400">{lang.toUpperCase()}</span>
          <span class="text-gray-300 dark:text-gray-600" aria-hidden="true">|</span>
          <a
            href={`/${otherLang}/`}
            onclick={`localStorage.setItem('lang','${otherLang}')`}
            class="text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-white transition-colors"
            aria-label={`Switch to ${otherLangLabel}`}
          >
            {otherLangLabel}
          </a>
        </div>

        <ThemeToggle client:load />
        <HamburgerMenu navLinks={navLinks} client:load />
      </div>
    </div>
  </nav>
</header>
